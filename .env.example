# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# Secret key for admin-only endpoints (/api/admin/clinic, /admin/clinics)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-me-to-a-random-secret

# ─── Clerk (auth — replaces custom JWT) ──────────────────────────────────────
# Run: clerk env pull --file .env    (once the project is linked)
# Clerk manages all auth: clinic staff sessions + owner magic links
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Public base URL of this server (used in caregiver email links)
# For local dev: http://localhost:3000
# For production: https://your-domain.com
BASE_URL=http://localhost:3000

# ─── Neon (Postgres) ─────────────────────────────────────────────────────────
# Production: create a database at https://console.neon.tech
#   or via Vercel dashboard → Storage → Create → Postgres (Neon)
#   Vercel auto-populates DATABASE_URL when linked.
# Local dev: install Postgres locally or use a free Neon dev branch URL.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Generated by: Vercel dashboard → Storage → Create → Blob
# Vercel auto-populates BLOB_READ_WRITE_TOKEN when linked.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Email via Resend ────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# "From" address — must be from a domain verified in your Resend account
# Resend free tier allows sending from onboarding@resend.dev for testing
EMAIL_FROM=Pet Protection Promise™ <noreply@yourdomain.com>

# ─── Site password gate (optional, pre-launch) ──────────────────────────────
# Gates the main app at / only (shareable links + webhooks stay public).
# Leave SITE_AUTH_PASS unset/empty to disable the gate (e.g. production launch).
SITE_AUTH_USER=dale
SITE_AUTH_PASS=test

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get webhook secret from https://dashboard.stripe.com/webhooks after creating
# an endpoint pointing to: https://yourapp.com/api/webhooks/stripe
# Subscribe the endpoint to: checkout.session.completed, invoice.paid,
# invoice.payment_failed, customer.subscription.updated/deleted, charge.refunded
STRIPE_WEBHOOK_SECRET=whsec_...
# NOTE: prices now live in the `products` table (managed in /admin). STRIPE_PRICE_USD
# is only a legacy fallback for the bare one-time checkout if no product exists.
STRIPE_PRICE_USD=3900

# ─── IFW cross-product integration (unified SaaS) ────────────────────────────
# Shared HMAC secret between IFW and Pet Promise. Generate once on IFW's side:
#   openssl rand -hex 32   — store the SAME value here and in IFW's env.
# Signs IFW→PP grant pushes, PP→IFW entitlement checks, and the signed metrics endpoint.
IFW_PP_WEBHOOK_SECRET=
# Base URL of IFW's backend (for live entitlement checks + routed billing).
# Same name Legacy Letter uses. Per IFW's example this is https://fivestarwills.ca
IFW_BASE_URL=
# Billing mode: 'local' (PP's own Stripe/PayPal — default) or 'ifw' (route all
# outsider checkout/portal through IFW's shared Stripe account — full consolidation).
# Flip to 'ifw' only once IFW's /api/integrations/* endpoints are live AND each
# product row carries its IFW Stripe price id. No local code is removed by flipping.
BILLING_MODE=local

# ─── PayPal ───────────────────────────────────────────────────────────────────
# Get credentials at https://developer.paypal.com/dashboard/applications
# PAYPAL_ENV: "sandbox" (default) for testing, "live" for production.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# Create a webhook at developer.paypal.com pointing to /api/webhooks/paypal,
# subscribe to PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.REFUNDED,
# BILLING.SUBSCRIPTION.ACTIVATED/CANCELLED/EXPIRED/SUSPENDED, PAYMENT.SALE.COMPLETED,
# then paste the generated Webhook ID here.
PAYPAL_WEBHOOK_ID=
