# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# Secret key for admin-only endpoints (/api/admin/clinic, /admin/clinics)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-me-to-a-random-secret

# ─── Clerk (auth — replaces custom JWT) ──────────────────────────────────────
# Run: clerk env pull --file .env    (once the project is linked)
# Clerk manages all auth: clinic staff sessions + owner magic links
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Public base URL of this server (used in caregiver email links)
# For local dev: http://localhost:3000
# For production: https://your-domain.com
BASE_URL=http://localhost:3000

# ─── Neon (Postgres) ─────────────────────────────────────────────────────────
# Production: create a database at https://console.neon.tech
#   or via Vercel dashboard → Storage → Create → Postgres (Neon)
#   Vercel auto-populates DATABASE_URL when linked.
# Local dev: install Postgres locally or use a free Neon dev branch URL.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Generated by: Vercel dashboard → Storage → Create → Blob
# Vercel auto-populates BLOB_READ_WRITE_TOKEN when linked.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com    SMTP_PASS=your-app-password
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=apikey             SMTP_PASS=SG.xxxxxxxxxxxx
#
# Mailgun example:
#   SMTP_HOST=smtp.mailgun.org   SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=postmaster@mg.yourdomain.com  SMTP_PASS=your-mailgun-smtp-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# The "From" address shown to the caregiver (defaults to SMTP_USER if blank)
SMTP_FROM=Pet Protection Promise™ <noreply@yourdomain.com>

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Get webhook secret from https://dashboard.stripe.com/webhooks after creating
# an endpoint pointing to: https://yourapp.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Price in cents (7900 = $79.00 USD)
STRIPE_PRICE_USD=7900
